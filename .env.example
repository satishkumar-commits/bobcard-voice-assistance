APP_ENV=development
LOG_LEVEL=INFO
LOCAL_UID=1000
LOCAL_GID=1000

TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_PHONE_NUMBER=
TWILIO_VALIDATE_WEBHOOK_SIGNATURE=true

SARVAM_API_KEY=
SARVAM_STT_MODEL=saaras:v3
SARVAM_STT_USE_STREAMING=true
SARVAM_STT_STREAMING_MODE=transcribe
SARVAM_STT_STREAMING_HIGH_VAD_SENSITIVITY=true
SARVAM_STT_STREAMING_TOTAL_TIMEOUT_SECONDS=8
SARVAM_STT_STREAMING_RECV_TIMEOUT_SECONDS=4
SARVAM_STT_STREAMING_COOLDOWN_SECONDS=20
SARVAM_STT_REST_TIMEOUT_SECONDS=15
SARVAM_TTS_MODEL=bulbul:v3
SARVAM_TTS_VOICE=shubh
SARVAM_TTS_PACE=1.08
SARVAM_TTS_SAMPLE_RATE=8000
SARVAM_TTS_ENABLE_PREPROCESSING=true
SARVAM_TTS_USE_STREAMING=true
SARVAM_TTS_OUTPUT_AUDIO_CODEC=mulaw

GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash

# Feature flags for phased streaming rollout
LLM_STREAMING=false
TTS_PERSISTENT_WS=true
TTS_NATIVE_MULAW=true

DATABASE_URL=sqlite:///./data/voice_agent.db
PUBLIC_URL=
LATENCY_LOGS_DIR=data/latency_logs
WEBRTC_ICE_SERVERS=stun:stun.l.google.com:19302
STT_CONFIDENCE_THRESHOLD=0.55
VAD_MIN_AUDIO_BYTES=8000
NOISY_CALL_RETRY_PROMPT_TRIGGER=2
NOISY_CALL_FALLBACK_TRIGGER=3
STREAM_VAD_BACKEND=webrtc
STREAM_VAD_RMS_THRESHOLD=320
STREAM_WEBRTC_VAD_AGGRESSIVENESS=2
STREAM_WEBRTC_VAD_FRAME_MS=20
STREAM_WEBRTC_VAD_MIN_SPEECH_RATIO=0.5
STREAM_VAD_SILENCE_MS=520
STREAM_VAD_MIN_SPEECH_MS=180
STREAM_VAD_MAX_SPEECH_MS=9000
STT_MODE=auto
STT_STREAM_RETRY_MAX=2
STT_STREAM_BACKOFF_MS=300
STT_STREAM_CB_FAILS=3
EMPTY_TRANSCRIPT_MIN_CHARS=3
BARGE_IN_MIN_SPEECH_MS=260
BARGE_IN_COOLDOWN_MS=220
STREAM_STT_TURN_TIMEOUT_SECONDS=10
STREAM_BARGE_IN_GRACE_MS=600
STREAM_BARGE_IN_MIN_PLAYBACK_MS=1000
STREAM_BARGE_IN_MIN_SPEECH_MS=450
TTS_CACHE_MAX_ENTRIES=96
SLO_ALERTS_ENABLED=true
SLO_ALERT_COOLDOWN_SECONDS=30
SLO_WINDOW_SIZE=40
SLO_STT_LATENCY_MS=3500
SLO_GEMINI_LATENCY_MS=4500
SLO_TTS_LATENCY_MS=3000
ROLLOUT_ENABLED=false
ROLLOUT_LLM_STREAMING_PERCENT=100
ROLLOUT_TTS_PERSISTENT_WS_PERCENT=100
ROLLOUT_TTS_NATIVE_MULAW_PERCENT=100
ROLLOUT_AUTO_ROLLBACK_ENABLED=true
ROLLOUT_ROLLBACK_CRITICAL_ALERTS_THRESHOLD=5
ROLLOUT_ROLLBACK_ALERT_WINDOW_SECONDS=300
ROLLOUT_ROLLBACK_DURATION_SECONDS=900
