APP_ENV=development
LOG_LEVEL=INFO
LOCAL_UID=1000
LOCAL_GID=1000

TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_PHONE_NUMBER=

SARVAM_API_KEY=
SARVAM_STT_MODEL=saaras:v3
SARVAM_STT_USE_STREAMING=true
SARVAM_STT_STREAMING_MODE=transcribe
SARVAM_STT_STREAMING_HIGH_VAD_SENSITIVITY=true
SARVAM_STT_STREAMING_TOTAL_TIMEOUT_SECONDS=8
SARVAM_STT_STREAMING_RECV_TIMEOUT_SECONDS=4
SARVAM_STT_STREAMING_COOLDOWN_SECONDS=20
SARVAM_STT_REST_TIMEOUT_SECONDS=15
SARVAM_TTS_MODEL=bulbul:v3
SARVAM_TTS_VOICE=shubh
SARVAM_TTS_PACE=1.08
SARVAM_TTS_SAMPLE_RATE=48000
SARVAM_TTS_ENABLE_PREPROCESSING=true

GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash

DATABASE_URL=sqlite:///./data/voice_agent.db
PUBLIC_URL=
LATENCY_LOGS_DIR=data/latency_logs
WEBRTC_ICE_SERVERS=stun:stun.l.google.com:19302
STT_CONFIDENCE_THRESHOLD=0.55
VAD_MIN_AUDIO_BYTES=8000
NOISY_CALL_RETRY_PROMPT_TRIGGER=2
NOISY_CALL_FALLBACK_TRIGGER=3
STREAM_VAD_RMS_THRESHOLD=320
STREAM_VAD_SILENCE_MS=520
STREAM_VAD_MIN_SPEECH_MS=180
STREAM_VAD_MAX_SPEECH_MS=9000
STREAM_STT_TURN_TIMEOUT_SECONDS=10
STREAM_BARGE_IN_GRACE_MS=220
STREAM_BARGE_IN_MIN_PLAYBACK_MS=420
STREAM_BARGE_IN_MIN_SPEECH_MS=160
TTS_CACHE_MAX_ENTRIES=96
